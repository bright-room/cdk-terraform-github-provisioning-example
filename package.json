{
  "name": "github-manager",
  "version": "1.0.0",
  "main": "main.js",
  "types": "main.ts",
  "license": "MPL-2.0",
  "private": true,
  "scripts": {
    "lint": "biome lint --write .",
    "fmt": "biome format --write .",
    "check": "biome check --write .",
    "plan": "cdktf diff --no-color",
    "apply": "cdktf deploy --no-color --auto-approve",
    "synth": "cdktf synth",
    "test": "jest",
    "test:watch": "jest --watch",
    "upgrade": "npm i cdktf@latest cdktf-cli@latest",
    "upgrade:next": "npm i cdktf@next cdktf-cli@next"
  },
  "engines": {
    "node": ">=20.19.6"
  },
  "dependencies": {
    "cdktf": "^0.21.0",
    "constructs": "^10.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@cdktf/provider-github": "^15.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
